10 GR_COLOR 255 : GR_CLEAR
20 GR_COLOR 142 : GR_MOVETO 150, 150 : CALL Box(50)
30 GR_COLOR 160 : GR_MOVETO 175, 125 : CALL Spiral(15)
50 GR_COLOR 154 : GR_MOVETO 50, 50 : GR_PRINT "Turtle Graphics!"
60 END
200 FUN Box(sz)
210   GR_PUSH : GR_PEN_DN
220   FOR I = 1 TO 4 : GR_FWD sz : GR_RT 90 : NEXT I
230   GR_PEN_UP : GR_POP
240   RETURN
300 FUN Spiral(steps)
310   GR_PUSH : GR_PEN_DN
320   FOR I = 1 TO steps: GR_FWD I * 3 : CALL Pnum(I) : GR_RT 31 : NEXT I
330   GR_POP : GR_PEN_UP
340   RETURN
350 FUN Pnum(n)
360   GR_PUSH
420   GR_FONT 12 : GR_COLOR 103 : GR_PRINT n
430   GR_POP
440   RETURN