10 REM RAYTRACER DEMO IN BWXBASIC
15 LET WHITE = GR_RGB(255,255,255) : LET BLACK = GR_RGB(0,0,0)
20 GR_COLOR BLACK : GR_CLEAR
30 W = 320 : H = 240
40 DIM SP_X(10), SP_Y(10), SP_Z(10), SP_R(10), SP_C0(10), SP_C1(10), SP_C2(10)
50 DIM BX_CX(10), BX_CY(10), BX_CZ(10), BX_HX(10), BX_HY(10), BX_HZ(10), BX_C0(10), BX_C1(10), BX_C2(10)
55 DIM BX_R00(10), BX_R01(10), BX_R02(10), BX_R10(10), BX_R11(10), BX_R12(10), BX_R20(10), BX_R21(10), BX_R22(10)
60 N_SP = 3 : N_BX = 4
70 SEED(TIME)
80 ' Generate Random Spheres
90 FOR I = 1 TO N_SP
100 SP_X(I) = (RND(1) * 6) - 3
110 SP_Y(I) = (RND(1) * 6) - 3
120 SP_Z(I) = (RND(1) * 5) + 5
130 SP_R(I) = RND(1) * 1.5 + 0.5
140 SP_C0(I) = INT(RND(1) * 255)
150 SP_C1(I) = INT(RND(1) * 255)
160 SP_C2(I) = INT(RND(1) * 255)
170 NEXT I
180 ' Generate Random Boxes
190 FOR I = 1 TO N_BX - 1
200 BX_CX(I) = (RND(1) * 6) - 3
210 BX_CY(I) = (RND(1) * 6) - 3
220 BX_CZ(I) = (RND(1) * 5) + 5
230 BX_HX(I) = RND(1) + 0.5 : BX_HY(I) = RND(1) + 0.5 : BX_HZ(I) = RND(1) + 0.5
240 AY = RND(1) * 6.28 : AX = RND(1) * 6.28
245 SY = SIN(AY) : CY = COS(AY) : SX = SIN(AX) : CX = COS(AX)
250 BX_R00(I) = CY : BX_R01(I) = SY*SX : BX_R02(I) = SY*CX
255 BX_R10(I) = 0.0 : BX_R11(I) = CX : BX_R12(I) = -SX
260 BX_R20(I) = -SY : BX_R21(I) = CY*SX : BX_R22(I) = CY*CX
270 BX_C0(I) = INT(RND(1) * 255)
280 BX_C1(I) = INT(RND(1) * 255)
290 BX_C2(I) = INT(RND(1) * 255)
300 NEXT I

305 ' Generate Ground Plane
306 BX_CX(N_BX) = 0.0 : BX_CY(N_BX) = -4.0 : BX_CZ(N_BX) = 10.0
307 BX_HX(N_BX) = 20.0 : BX_HY(N_BX) = 0.1 : BX_HZ(N_BX) = 20.0
308 BX_R00(N_BX) = 1.0 : BX_R01(N_BX) = 0.0 : BX_R02(N_BX) = 0.0
309 BX_R10(N_BX) = 0.0 : BX_R11(N_BX) = 1.0 : BX_R12(N_BX) = 0.0
310 BX_R20(N_BX) = 0.0 : BX_R21(N_BX) = 0.0 : BX_R22(N_BX) = 1.0
311 BX_C0(N_BX) = 150 : BX_C1(N_BX) = 150 : BX_C2(N_BX) = 150

301 ' Setup Dither Matrix
302 DIM BAYER(3,3)
303 BAYER(0,0)=0: BAYER(1,0)=8: BAYER(2,0)=2: BAYER(3,0)=10
304 BAYER(0,1)=12: BAYER(1,1)=4: BAYER(2,1)=14: BAYER(3,1)=6
305 BAYER(0,2)=3: BAYER(1,2)=11: BAYER(2,2)=1: BAYER(3,2)=9
306 BAYER(0,3)=15: BAYER(1,3)=7: BAYER(2,3)=13: BAYER(3,3)=5
307 FOR BY = 0 TO 3: FOR BX = 0 TO 3: BAYER(BX,BY) = (BAYER(BX,BY) / 16.0) - 0.5 : NEXT BX : NEXT BY

310 PRINT "Rendering raytracer scene (" + STR$(W) + "x" + STR$(H) + ")..."
320 ' Main Raytracing Loop
330 FOR Y = 0 TO H - 1
340 FOR X = 0 TO W - 1
370 OX = 0.0 : OY = 0.0 : OZ = 0.0
380 DX = (X / W) * 2.0 - 1.0
390 DY = ((H - 1 - Y) / H) * 2.0 - 1.0
400 DZ = 1.6 : REM "focal length" approximately
410 DL = SQR(DX*DX + DY*DY + DZ*DZ)
420 DX = DX / DL : DY = DY / DL : DZ = DZ / DL
430 CLR = CALL TRACE(OX, OY, OZ, DX, DY, DZ, X, Y)
440 GR_COLOR = CLR
450 GR_MOVETO X, Y
460 GR_FRECT 1, 1
470 NEXT X
475 DELAY 0
480 NEXT Y
490 PRINT "Done Render."
500 END
1000 FUN I_SPH(OX, OY, OZ, DX, DY, DZ, CX, CY, CZ, R)
1010 OCX = OX - CX : OCY = OY - CY : OCZ = OZ - CZ
1020 B = 2.0 * (OCX * DX + OCY * DY + OCZ * DZ)
1030 C = (OCX * OCX + OCY * OCY + OCZ * OCZ) - R * R
1040 D = B * B - 4.0 * C
1050 IF D < 0.0 THEN RETURN -1.0
1060 T1 = (-B - SQR(D)) / 2.0
1070 IF T1 > 0.001 THEN RETURN T1
1080 T2 = (-B + SQR(D)) / 2.0
1090 IF T2 > 0.001 THEN RETURN T2
2000 FUN I_BOX(OX, OY, OZ, DX, DY, DZ, I)
2005 TX = OX - BX_CX(I) : TY = OY - BX_CY(I) : TZ = OZ - BX_CZ(I)
2010 LOX = TX * BX_R00(I) + TY * BX_R10(I) + TZ * BX_R20(I)
2015 LOY = TX * BX_R01(I) + TY * BX_R11(I) + TZ * BX_R21(I)
2020 LOZ = TX * BX_R02(I) + TY * BX_R12(I) + TZ * BX_R22(I)
2025 LDX = DX * BX_R00(I) + DY * BX_R10(I) + DZ * BX_R20(I)
2030 LDY = DX * BX_R01(I) + DY * BX_R11(I) + DZ * BX_R21(I)
2035 LDZ = DX * BX_R02(I) + DY * BX_R12(I) + DZ * BX_R22(I)
2040 TX1 = (-BX_HX(I) - LOX) / (LDX + 0.000001)
2045 TX2 = (BX_HX(I) - LOX) / (LDX + 0.000001)
2050 TY1 = (-BX_HY(I) - LOY) / (LDY + 0.000001)
2055 TY2 = (BX_HY(I) - LOY) / (LDY + 0.000001)
2060 TZ1 = (-BX_HZ(I) - LOZ) / (LDZ + 0.000001)
2065 TZ2 = (BX_HZ(I) - LOZ) / (LDZ + 0.000001)
2070 TMIN = TX1 : IF TX2 < TX1 THEN TMIN = TX2
2080 TMAX = TX1 : IF TX2 > TX1 THEN TMAX = TX2
2090 TYMIN = TY1 : IF TY2 < TY1 THEN TYMIN = TY2
2100 TYMAX = TY1 : IF TY2 > TY1 THEN TYMAX = TY2
2110 IF TYMIN > TMIN THEN TMIN = TYMIN
2120 IF TYMAX < TMAX THEN TMAX = TYMAX
2130 TZMIN = TZ1 : IF TZ2 < TZ1 THEN TZMIN = TZ2
2140 TZMAX = TZ1 : IF TZ2 > TZ1 THEN TZMAX = TZ2
2150 IF TZMIN > TMIN THEN TMIN = TZMIN
2160 IF TZMAX < TMAX THEN TMAX = TZMAX
2170 IF TMAX < TMIN THEN RETURN -1.0
2180 IF TMAX < 0.0 THEN RETURN -1.0
2190 IF TMIN > 0.001 THEN RETURN TMIN
2200 RETURN TMAX
2210 RETURN 0
3000 FUN TRACE(OX, OY, OZ, DX, DY, DZ, PX_X, PX_Y)
3010 HIT = CALL GET_SCENE(OX, OY, OZ, DX, DY, DZ)
3020 IF HIT = 0 THEN DR=0 : DG=0 : DB = INT((DY + 1.0) * 127) : GOTO 3500
3030 P_T = G_HIT_T : P_TYPE = G_HIT_TYPE
3040 P_PX = G_PX : P_PY = G_PY : P_PZ = G_PZ
3050 P_NX = G_NX : P_NY = G_NY : P_NZ = G_NZ
3060 P_CR = G_CR : P_CG = G_CG : P_CB = G_CB
3070 ' Base Shadows
3080 LX = 0.577 : LY = 0.577 : LZ = -0.577 : SHAD = 0.0
3090 HIT2 = CALL GET_SCENE(P_PX + P_NX*0.01, P_PY + P_NY*0.01, P_PZ + P_NZ*0.01, LX, LY, LZ)
3100 IF HIT2 = 1 THEN SHAD = 1.0
3110 NDL = P_NX * LX + P_NY * LY + P_NZ * LZ : IF NDL < 0 THEN NDL = 0.0
3120 DIFF = 0.2 + 0.8 * NDL * (1.0 - SHAD)
3130 DR = P_CR * DIFF : DG = P_CG * DIFF : DB = P_CB * DIFF
3140 ' Reflections (if sphere)
3150 IF P_TYPE = 2 THEN GOTO 3500
3160 DOT = DX * P_NX + DY * P_NY + DZ * P_NZ
3170 RX = DX - 2.0 * DOT * P_NX : RY = DY - 2.0 * DOT * P_NY : RZ = DZ - 2.0 * DOT * P_NZ
3180 HIT3 = CALL GET_SCENE(P_PX + P_NX*0.01, P_PY + P_NY*0.01, P_PZ + P_NZ*0.01, RX, RY, RZ)
3190 IF HIT3 = 0 THEN DR = DR : DG = DG : DB = DB + INT((RY + 1.0) * 127) * 0.5 : GOTO 3500
3200 R_NDL = G_NX * LX + G_NY * LY + G_NZ * LZ : IF R_NDL < 0 THEN R_NDL = 0.0
3210 R_DIFF = 0.2 + 0.8 * R_NDL
3220 DR = (DR * 0.5) + (G_CR * R_DIFF * 0.5)
3230 DG = (DG * 0.5) + (G_CG * R_DIFF * 0.5)
3240 DB = (DB * 0.5) + (G_CB * R_DIFF * 0.5)
3500 ' End Shading / Dither
3510 M_X = PX_X - INT(PX_X/4)*4
3520 M_Y = PX_Y - INT(PX_Y/4)*4
3530 DITH = BAYER(M_X, M_Y) * 64.0
3540 DR = DR + DITH : DG = DG + DITH : DB = DB + DITH
3550 IF DR < 0 THEN DR = 0
3560 IF DR > 255 THEN DR = 255
3570 IF DG < 0 THEN DG = 0
3580 IF DG > 255 THEN DG = 255
3590 IF DB < 0 THEN DB = 0
3600 IF DB > 255 THEN DB = 255
3610 RETURN GR_RGB(INT(DR), INT(DG), INT(DB))
3620 RETURN 0

4000 FUN GET_SCENE(OX, OY, OZ, DX, DY, DZ)
4010 G_HIT_T = 10000.0 : G_HIT_ID = -1 : G_HIT_TYPE = 0
4020 FOR I = 1 TO N_SP
4030   T = CALL I_SPH(OX, OY, OZ, DX, DY, DZ, SP_X(I), SP_Y(I), SP_Z(I), SP_R(I))
4040   IF T > 0 AND T < G_HIT_T THEN G_HIT_T = T : G_HIT_ID = I : G_HIT_TYPE = 1
4050 NEXT I
4060 FOR I = 1 TO N_BX
4070   T = CALL I_BOX(OX, OY, OZ, DX, DY, DZ, I)
4080   IF T > 0 AND T < G_HIT_T THEN G_HIT_T = T : G_HIT_ID = I : G_HIT_TYPE = 2
4090 NEXT I
4100 IF G_HIT_TYPE = 0 THEN RETURN 0
4110 G_PX = OX + DX * G_HIT_T : G_PY = OY + DY * G_HIT_T : G_PZ = OZ + DZ * G_HIT_T
4120 IF G_HIT_TYPE = 2 THEN GOTO 4200
4130 ' Sphere Hit Output
4140 G_NX = G_PX - SP_X(G_HIT_ID) : G_NY = G_PY - SP_Y(G_HIT_ID) : G_NZ = G_PZ - SP_Z(G_HIT_ID)
4150 NL = SQR(G_NX*G_NX + G_NY*G_NY + G_NZ*G_NZ)
4160 G_NX = G_NX / NL : G_NY = G_NY / NL : G_NZ = G_NZ / NL
4170 G_CR = SP_C0(G_HIT_ID) : G_CG = SP_C1(G_HIT_ID) : G_CB = SP_C2(G_HIT_ID)
4180 RETURN 1
4200 ' Box Hit Output
4210 TX = G_PX - BX_CX(G_HIT_ID) : TY = G_PY - BX_CY(G_HIT_ID) : TZ = G_PZ - BX_CZ(G_HIT_ID)
4220 LPX = TX * BX_R00(G_HIT_ID) + TY * BX_R10(G_HIT_ID) + TZ * BX_R20(G_HIT_ID)
4230 LPY = TX * BX_R01(G_HIT_ID) + TY * BX_R11(G_HIT_ID) + TZ * BX_R21(G_HIT_ID)
4240 LPZ = TX * BX_R02(G_HIT_ID) + TY * BX_R12(G_HIT_ID) + TZ * BX_R22(G_HIT_ID)
4250 DXB = ABS(LPX) / (BX_HX(G_HIT_ID) + 0.000001)
4260 DYB = ABS(LPY) / (BX_HY(G_HIT_ID) + 0.000001)
4270 DZB = ABS(LPZ) / (BX_HZ(G_HIT_ID) + 0.000001)
4280 MAXB = DXB
4290 IF DYB > MAXB THEN MAXB = DYB
4300 IF DZB > MAXB THEN MAXB = DZB
4310 LNX = 0.0 : LNY = 0.0 : LNZ = 0.0
4320 IF MAXB = DXB THEN LNX = SGN(LPX)
4330 IF MAXB = DYB THEN LNY = SGN(LPY)
4340 IF MAXB = DZB THEN LNZ = SGN(LPZ)
4350 G_NX = LNX * BX_R00(G_HIT_ID) + LNY * BX_R01(G_HIT_ID) + LNZ * BX_R02(G_HIT_ID)
4360 G_NY = LNX * BX_R10(G_HIT_ID) + LNY * BX_R11(G_HIT_ID) + LNZ * BX_R12(G_HIT_ID)
4370 G_NZ = LNX * BX_R20(G_HIT_ID) + LNY * BX_R21(G_HIT_ID) + LNZ * BX_R22(G_HIT_ID)
4380 G_CR = BX_C0(G_HIT_ID) : G_CG = BX_C1(G_HIT_ID) : G_CB = BX_C2(G_HIT_ID)
4390 RETURN 1

