10 REM RAYTRACER DEMO IN BWXBASIC
15 LET WHITE = GR_RGB(255,255,255) : LET BLACK = GR_RGB(0,0,0)
20 GR_COLOR BLACK : GR_CLEAR
30 W = 128 : H = 128
40 DIM SP_X(10), SP_Y(10), SP_Z(10), SP_R(10), SP_C0(10), SP_C1(10), SP_C2(10)
50 DIM BX_X0(10), BX_Y0(10), BX_Z0(10), BX_X1(10), BX_Y1(10), BX_Z1(10), BX_C0(10), BX_C1(10), BX_C2(10)
60 N_SP = 3 : N_BX = 3
70 SEED(TIME)
80 ' Generate Random Spheres
90 FOR I = 1 TO N_SP
100 SP_X(I) = (RND(1) * 6) - 3
110 SP_Y(I) = (RND(1) * 6) - 3
120 SP_Z(I) = (RND(1) * 5) + 5
130 SP_R(I) = RND(1) * 1.5 + 0.5
140 SP_C0(I) = INT(RND(1) * 255)
150 SP_C1(I) = INT(RND(1) * 255)
160 SP_C2(I) = INT(RND(1) * 255)
170 NEXT I
180 ' Generate Random Boxes
190 FOR I = 1 TO N_BX
200 CX = (RND(1) * 6) - 3
210 CY = (RND(1) * 6) - 3
220 CZ = (RND(1) * 5) + 5
230 S_X = RND(1) + 0.5 : S_Y = RND(1) + 0.5 : S_Z = RND(1) + 0.5
240 BX_X0(I) = CX - S_X : BX_X1(I) = CX + S_X
250 BX_Y0(I) = CY - S_Y : BX_Y1(I) = CY + S_Y
260 BX_Z0(I) = CZ - S_Z : BX_Z1(I) = CZ + S_Z
270 BX_C0(I) = INT(RND(1) * 255)
280 BX_C1(I) = INT(RND(1) * 255)
290 BX_C2(I) = INT(RND(1) * 255)
300 NEXT I
310 PRINT "Rendering raytracer scene (" + STR$(W) + "x" + STR$(H) + ")..."
320 ' Main Raytracing Loop
330 FOR Y = 0 TO H - 1
340 FOR X = 0 TO W - 1
370 OX = 0.0 : OY = 0.0 : OZ = 0.0
380 DX = (X / W) * 2.0 - 1.0
390 DY = ((H - 1 - Y) / H) * 2.0 - 1.0
400 DZ = 1.0
410 DL = SQR(DX*DX + DY*DY + DZ*DZ)
420 DX = DX / DL : DY = DY / DL : DZ = DZ / DL
430 CLR = CALL TRACE(OX, OY, OZ, DX, DY, DZ)
440 GR_COLOR = CLR
450 GR_MOVETO X, Y
460 GR_FRECT 1, 1
465 delay 0
470 NEXT X
480 NEXT Y
490 PRINT "Done Render."
500 END
1000 FUN I_SPH(OX, OY, OZ, DX, DY, DZ, CX, CY, CZ, R)
1010 OCX = OX - CX : OCY = OY - CY : OCZ = OZ - CZ
1020 B = 2.0 * (OCX * DX + OCY * DY + OCZ * DZ)
1030 C = (OCX * OCX + OCY * OCY + OCZ * OCZ) - R * R
1040 D = B * B - 4.0 * C
1050 IF D < 0.0 THEN RETURN -1.0
1060 T1 = (-B - SQR(D)) / 2.0
1070 IF T1 > 0.001 THEN RETURN T1
1080 T2 = (-B + SQR(D)) / 2.0
1090 IF T2 > 0.001 THEN RETURN T2
1100 RETURN -1.0
1110 RETURN 0
2000 FUN I_BOX(OX, OY, OZ, DX, DY, DZ, X0, Y0, Z0, X1, Y1, Z1)
2010 TX1 = (X0 - OX) / (DX + 0.000001)
2020 TX2 = (X1 - OX) / (DX + 0.000001)
2030 TY1 = (Y0 - OY) / (DY + 0.000001)
2040 TY2 = (Y1 - OY) / (DY + 0.000001)
2050 TZ1 = (Z0 - OZ) / (DZ + 0.000001)
2060 TZ2 = (Z1 - OZ) / (DZ + 0.000001)
2070 TMIN = TX1 : IF TX2 < TX1 THEN TMIN = TX2
2080 TMAX = TX1 : IF TX2 > TX1 THEN TMAX = TX2
2090 TYMIN = TY1 : IF TY2 < TY1 THEN TYMIN = TY2
2100 TYMAX = TY1 : IF TY2 > TY1 THEN TYMAX = TY2
2110 IF TYMIN > TMIN THEN TMIN = TYMIN
2120 IF TYMAX < TMAX THEN TMAX = TYMAX
2130 TZMIN = TZ1 : IF TZ2 < TZ1 THEN TZMIN = TZ2
2140 TZMAX = TZ1 : IF TZ2 > TZ1 THEN TZMAX = TZ2
2150 IF TZMIN > TMIN THEN TMIN = TZMIN
2160 IF TZMAX < TMAX THEN TMAX = TZMAX
2170 IF TMAX < TMIN THEN RETURN -1.0
2180 IF TMAX < 0.0 THEN RETURN -1.0
2190 IF TMIN > 0.001 THEN RETURN TMIN
2200 RETURN TMAX
2210 RETURN 0
3000 FUN TRACE(OX, OY, OZ, DX, DY, DZ)
3010 MT = 10000.0
3020 HIT_ID = -1
3030 HIT_TYPE = 0
3040 FOR I = 1 TO N_SP
3050 T = CALL I_SPH(OX, OY, OZ, DX, DY, DZ, SP_X(I), SP_Y(I), SP_Z(I), SP_R(I))
3060 IF T > 0 AND T < MT THEN MT = T : HIT_ID = I : HIT_TYPE = 1
3070 NEXT I
3080 FOR I = 1 TO N_BX
3090 T = CALL I_BOX(OX, OY, OZ, DX, DY, DZ, BX_X0(I), BX_Y0(I), BX_Z0(I), BX_X1(I), BX_Y1(I), BX_Z1(I))
3100 IF T > 0 AND T < MT THEN MT = T : HIT_ID = I : HIT_TYPE = 2
3110 NEXT I
3120 IF HIT_TYPE = 0 THEN RETURN GR_RGB(0, 0, INT((DY + 1.0) * 127))
3130 PX = OX + DX * MT
3140 PY = OY + DY * MT
3150 PZ = OZ + DZ * MT
3160 NX = 0.0 : NY = 0.0 : NZ = 0.0
3170 CR = 0 : CG = 0 : CB = 0
3180 IF HIT_TYPE = 2 THEN GOTO 3300
3190 ' Sphere Normal and Color
3200 NX = PX - SP_X(HIT_ID)
3210 NY = PY - SP_Y(HIT_ID)
3220 NZ = PZ - SP_Z(HIT_ID)
3230 NL = SQR(NX*NX + NY*NY + NZ*NZ)
3240 NX = NX / NL : NY = NY / NL : NZ = NZ / NL
3250 CR = SP_C0(HIT_ID) : CG = SP_C1(HIT_ID) : CB = SP_C2(HIT_ID)
3260 GOTO 3500
3300 ' Box Normal and Color
3310 CEN_X = (BX_X0(HIT_ID) + BX_X1(HIT_ID)) * 0.5
3320 CEN_Y = (BX_Y0(HIT_ID) + BX_Y1(HIT_ID)) * 0.5
3330 CEN_Z = (BX_Z0(HIT_ID) + BX_Z1(HIT_ID)) * 0.5
3340 DXB = ABS(PX - CEN_X) / (ABS(BX_X1(HIT_ID) - BX_X0(HIT_ID)) * 0.5 + 0.000001)
3350 DYB = ABS(PY - CEN_Y) / (ABS(BX_Y1(HIT_ID) - BX_Y0(HIT_ID)) * 0.5 + 0.000001)
3360 DZB = ABS(PZ - CEN_Z) / (ABS(BX_Z1(HIT_ID) - BX_Z0(HIT_ID)) * 0.5 + 0.000001)
3370 MAXB = DXB
3380 IF DYB > MAXB THEN MAXB = DYB
3390 IF DZB > MAXB THEN MAXB = DZB
3400 IF MAXB = DXB THEN NX = SGN(PX - CEN_X)
3410 IF MAXB = DYB THEN NY = SGN(PY - CEN_Y)
3420 IF MAXB = DZB THEN NZ = SGN(PZ - CEN_Z)
3430 CR = BX_C0(HIT_ID) : CG = BX_C1(HIT_ID) : CB = BX_C2(HIT_ID)
3500 ' Lambertian Diffuse Shading
3510 LX = 0.577 : LY = 0.577 : LZ = -0.577
3520 NDL = NX * LX + NY * LY + NZ * LZ
3530 IF NDL < 0 THEN NDL = 0.0
3540 DIFF = 0.2 + 0.8 * NDL
3550 RETURN GR_RGB(INT(CR * DIFF), INT(CG * DIFF), INT(CB * DIFF))
3560 RETURN 0

