10 REM RAYTRACER DEMO IN BWXBASIC
15 LET WHITE = GR_RGB(255,255,255) : LET BLACK = GR_RGB(0,0,0)
20 GR_COLOR BLACK : GR_CLEAR
30 W = 320 : H = 240
40 DIM SP_X(10), SP_Y(10), SP_Z(10), SP_R(10), SP_C0(10), SP_C1(10), SP_C2(10)
50 DIM BX_CX(10), BX_CY(10), BX_CZ(10), BX_HX(10), BX_HY(10), BX_HZ(10), BX_C0(10), BX_C1(10), BX_C2(10)
55 DIM BX_R00(10), BX_R01(10), BX_R02(10), BX_R10(10), BX_R11(10), BX_R12(10), BX_R20(10), BX_R21(10), BX_R22(10)
60 N_SP = 3 : N_BX = 3
70 SEED(TIME)
80 ' Generate Random Spheres
90 FOR I = 1 TO N_SP
100 SP_X(I) = (RND(1) * 6) - 3
110 SP_Y(I) = (RND(1) * 6) - 3
120 SP_Z(I) = (RND(1) * 5) + 5
130 SP_R(I) = RND(1) * 1.5 + 0.5
140 SP_C0(I) = INT(RND(1) * 255)
150 SP_C1(I) = INT(RND(1) * 255)
160 SP_C2(I) = INT(RND(1) * 255)
170 NEXT I
180 ' Generate Random Boxes
190 FOR I = 1 TO N_BX
200 BX_CX(I) = (RND(1) * 6) - 3
210 BX_CY(I) = (RND(1) * 6) - 3
220 BX_CZ(I) = (RND(1) * 5) + 5
230 BX_HX(I) = RND(1) + 0.5 : BX_HY(I) = RND(1) + 0.5 : BX_HZ(I) = RND(1) + 0.5
240 AY = RND(1) * 6.28 : AX = RND(1) * 6.28
245 SY = SIN(AY) : CY = COS(AY) : SX = SIN(AX) : CX = COS(AX)
250 BX_R00(I) = CY : BX_R01(I) = SY*SX : BX_R02(I) = SY*CX
255 BX_R10(I) = 0.0 : BX_R11(I) = CX : BX_R12(I) = -SX
260 BX_R20(I) = -SY : BX_R21(I) = CY*SX : BX_R22(I) = CY*CX
270 BX_C0(I) = INT(RND(1) * 255)
280 BX_C1(I) = INT(RND(1) * 255)
290 BX_C2(I) = INT(RND(1) * 255)
300 NEXT I

301 ' Setup Dither Matrix
302 DIM BAYER(3,3)
303 BAYER(0,0)=0: BAYER(1,0)=8: BAYER(2,0)=2: BAYER(3,0)=10
304 BAYER(0,1)=12: BAYER(1,1)=4: BAYER(2,1)=14: BAYER(3,1)=6
305 BAYER(0,2)=3: BAYER(1,2)=11: BAYER(2,2)=1: BAYER(3,2)=9
306 BAYER(0,3)=15: BAYER(1,3)=7: BAYER(2,3)=13: BAYER(3,3)=5
307 FOR BY = 0 TO 3: FOR BX = 0 TO 3: BAYER(BX,BY) = (BAYER(BX,BY) / 16.0) - 0.5 : NEXT BX : NEXT BY

310 PRINT "Rendering raytracer scene (" + STR$(W) + "x" + STR$(H) + ")..."
320 ' Main Raytracing Loop
330 FOR Y = 0 TO H - 1
340 FOR X = 0 TO W - 1
370 OX = 0.0 : OY = 0.0 : OZ = 0.0
380 DX = (X / W) * 2.0 - 1.0
390 DY = ((H - 1 - Y) / H) * 2.0 - 1.0
400 DZ = 1.6 : REM "focal length" approximately
410 DL = SQR(DX*DX + DY*DY + DZ*DZ)
420 DX = DX / DL : DY = DY / DL : DZ = DZ / DL
430 CLR = CALL TRACE(OX, OY, OZ, DX, DY, DZ, X, Y)
440 GR_COLOR = CLR
450 GR_MOVETO X, Y
460 GR_FRECT 1, 1
470 NEXT X
475 DELAY 0
480 NEXT Y
490 PRINT "Done Render."
500 END
1000 FUN I_SPH(OX, OY, OZ, DX, DY, DZ, CX, CY, CZ, R)
1010 OCX = OX - CX : OCY = OY - CY : OCZ = OZ - CZ
1020 B = 2.0 * (OCX * DX + OCY * DY + OCZ * DZ)
1030 C = (OCX * OCX + OCY * OCY + OCZ * OCZ) - R * R
1040 D = B * B - 4.0 * C
1050 IF D < 0.0 THEN RETURN -1.0
1060 T1 = (-B - SQR(D)) / 2.0
1070 IF T1 > 0.001 THEN RETURN T1
1080 T2 = (-B + SQR(D)) / 2.0
1090 IF T2 > 0.001 THEN RETURN T2
2000 FUN I_BOX(OX, OY, OZ, DX, DY, DZ, I)
2005 TX = OX - BX_CX(I) : TY = OY - BX_CY(I) : TZ = OZ - BX_CZ(I)
2010 LOX = TX * BX_R00(I) + TY * BX_R10(I) + TZ * BX_R20(I)
2015 LOY = TX * BX_R01(I) + TY * BX_R11(I) + TZ * BX_R21(I)
2020 LOZ = TX * BX_R02(I) + TY * BX_R12(I) + TZ * BX_R22(I)
2025 LDX = DX * BX_R00(I) + DY * BX_R10(I) + DZ * BX_R20(I)
2030 LDY = DX * BX_R01(I) + DY * BX_R11(I) + DZ * BX_R21(I)
2035 LDZ = DX * BX_R02(I) + DY * BX_R12(I) + DZ * BX_R22(I)
2040 TX1 = (-BX_HX(I) - LOX) / (LDX + 0.000001)
2045 TX2 = (BX_HX(I) - LOX) / (LDX + 0.000001)
2050 TY1 = (-BX_HY(I) - LOY) / (LDY + 0.000001)
2055 TY2 = (BX_HY(I) - LOY) / (LDY + 0.000001)
2060 TZ1 = (-BX_HZ(I) - LOZ) / (LDZ + 0.000001)
2065 TZ2 = (BX_HZ(I) - LOZ) / (LDZ + 0.000001)
2070 TMIN = TX1 : IF TX2 < TX1 THEN TMIN = TX2
2080 TMAX = TX1 : IF TX2 > TX1 THEN TMAX = TX2
2090 TYMIN = TY1 : IF TY2 < TY1 THEN TYMIN = TY2
2100 TYMAX = TY1 : IF TY2 > TY1 THEN TYMAX = TY2
2110 IF TYMIN > TMIN THEN TMIN = TYMIN
2120 IF TYMAX < TMAX THEN TMAX = TYMAX
2130 TZMIN = TZ1 : IF TZ2 < TZ1 THEN TZMIN = TZ2
2140 TZMAX = TZ1 : IF TZ2 > TZ1 THEN TZMAX = TZ2
2150 IF TZMIN > TMIN THEN TMIN = TZMIN
2160 IF TZMAX < TMAX THEN TMAX = TZMAX
2170 IF TMAX < TMIN THEN RETURN -1.0
2180 IF TMAX < 0.0 THEN RETURN -1.0
2190 IF TMIN > 0.001 THEN RETURN TMIN
2200 RETURN TMAX
2210 RETURN 0
3000 FUN TRACE(OX, OY, OZ, DX, DY, DZ, PX_X, PX_Y)
3010 MT = 10000.0
3020 HIT_ID = -1
3030 HIT_TYPE = 0
3040 FOR I = 1 TO N_SP
3050 T = CALL I_SPH(OX, OY, OZ, DX, DY, DZ, SP_X(I), SP_Y(I), SP_Z(I), SP_R(I))
3060 IF T > 0 AND T < MT THEN MT = T : HIT_ID = I : HIT_TYPE = 1
3070 NEXT I
3080 FOR I = 1 TO N_BX
3090 T = CALL I_BOX(OX, OY, OZ, DX, DY, DZ, I)
3100 IF T > 0 AND T < MT THEN MT = T : HIT_ID = I : HIT_TYPE = 2
3110 NEXT I
3120 IF HIT_TYPE = 0 THEN RETURN GR_RGB(0, 0, INT((DY + 1.0) * 127))
3130 PX = OX + DX * MT
3140 PY = OY + DY * MT
3150 PZ = OZ + DZ * MT
3160 NX = 0.0 : NY = 0.0 : NZ = 0.0
3170 CR = 0 : CG = 0 : CB = 0
3180 IF HIT_TYPE = 2 THEN GOTO 3300
3190 ' Sphere Normal and Color
3200 NX = PX - SP_X(HIT_ID)
3210 NY = PY - SP_Y(HIT_ID)
3220 NZ = PZ - SP_Z(HIT_ID)
3230 NL = SQR(NX*NX + NY*NY + NZ*NZ)
3240 NX = NX / NL : NY = NY / NL : NZ = NZ / NL
3250 CR = SP_C0(HIT_ID) : CG = SP_C1(HIT_ID) : CB = SP_C2(HIT_ID)
3260 GOTO 3500
3300 ' Box Normal and Color
3305 TX = PX - BX_CX(HIT_ID) : TY = PY - BX_CY(HIT_ID) : TZ = PZ - BX_CZ(HIT_ID)
3310 LPX = TX * BX_R00(HIT_ID) + TY * BX_R10(HIT_ID) + TZ * BX_R20(HIT_ID)
3315 LPY = TX * BX_R01(HIT_ID) + TY * BX_R11(HIT_ID) + TZ * BX_R21(HIT_ID)
3320 LPZ = TX * BX_R02(HIT_ID) + TY * BX_R12(HIT_ID) + TZ * BX_R22(HIT_ID)
3330 DXB = ABS(LPX) / (BX_HX(HIT_ID) + 0.000001)
3340 DYB = ABS(LPY) / (BX_HY(HIT_ID) + 0.000001)
3350 DZB = ABS(LPZ) / (BX_HZ(HIT_ID) + 0.000001)
3370 MAXB = DXB
3380 IF DYB > MAXB THEN MAXB = DYB
3390 IF DZB > MAXB THEN MAXB = DZB
3395 LNX = 0.0 : LNY = 0.0 : LNZ = 0.0
3400 IF MAXB = DXB THEN LNX = SGN(LPX)
3410 IF MAXB = DYB THEN LNY = SGN(LPY)
3420 IF MAXB = DZB THEN LNZ = SGN(LPZ)
3425 NX = LNX * BX_R00(HIT_ID) + LNY * BX_R01(HIT_ID) + LNZ * BX_R02(HIT_ID)
3426 NY = LNX * BX_R10(HIT_ID) + LNY * BX_R11(HIT_ID) + LNZ * BX_R12(HIT_ID)
3427 NZ = LNX * BX_R20(HIT_ID) + LNY * BX_R21(HIT_ID) + LNZ * BX_R22(HIT_ID)
3430 CR = BX_C0(HIT_ID) : CG = BX_C1(HIT_ID) : CB = BX_C2(HIT_ID)
3500 ' Lambertian Diffuse Shading
3510 LX = 0.577 : LY = 0.577 : LZ = -0.577
3520 NDL = NX * LX + NY * LY + NZ * LZ
3530 IF NDL < 0 THEN NDL = 0.0
3540 DIFF = 0.2 + 0.8 * NDL
3542 DR = CR * DIFF : DG = CG * DIFF : DB = CB * DIFF
3543 M_X = PX_X - INT(PX_X/4)*4
3544 M_Y = PX_Y - INT(PX_Y/4)*4
3545 DITH = BAYER(M_X, M_Y) * 64.0
3546 DR = DR + DITH : DG = DG + DITH : DB = DB + DITH
3547 IF DR < 0 THEN DR = 0
3548 IF DR > 255 THEN DR = 255
3549 IF DG < 0 THEN DG = 0
3550 IF DG > 255 THEN DG = 255
3551 IF DB < 0 THEN DB = 0
3552 IF DB > 255 THEN DB = 255
3560 RETURN GR_RGB(INT(DR), INT(DG), INT(DB))
3560 RETURN 0

