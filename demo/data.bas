10 REM =========================================
20 REM DATA STRUCTURES DEMO
30 REM SHOWCASING: ARRAY, DICT, DIM, DATA, READ
40 REM =========================================
50 PRINT "1. USING ARRAY TO INITIALIZE A LIST:"
60 ARRAY A(10, 20, 30, 40, 50)
70 FOR I = 0 TO 4
80   PRINT "  A("; I; ") = "; A(I)
90 NEXT I
100 PRINT ""
110 PRINT "2. USING DICT TO CREATE A DICTIONARY:"
120 DICT D("name", "bwxBASIC", "version", SYS("VERSION"), "awesome", 1)
130 FORKEYS K, D
140   PRINT "  D("; K; ") = "; D(K)
150 NEXT K
160 PRINT ""
170 PRINT "3. USING DIM TO ALLOCATE AND READ WITH DATA:"
180 DIM M(2, 2)
190 REM READ 9 VALUES INTO M
200 READ M, 9
210 FOR Y = 0 TO 2
220   FOR X = 0 TO 2
230     PRINT "  M("; X; ", "; Y; ") = "; M(X, Y)
240   NEXT X
250 NEXT Y
260 PRINT ""
270 PRINT "4. READING DATA INTO A DICT:"
280 DICT INVENTORY()
290 REM READ 3 KEY-VALUE PAIRS (6 ITEMS) INTO INVENTORY
300 READ INVENTORY, 3
310 FORKEYS K, INVENTORY
320   PRINT "  INVENTORY("; K; ") = "; INVENTORY(K)
330 NEXT K
331 PRINT ""
332 PRINT "5. PRINTING ENTIRE ARRAY AND DICT VALUES:"
333 PRINT "  A = "; A
334 PRINT "  STR(A) = "; STR(A)
335 PRINT "  D = "; D
336 PRINT "  M = "; M
337 PRINT "  INVENTORY = "; INVENTORY
340 END
500 REM --- DATA BLOCK ---
510 DATA 1, 2, 3
520 DATA 4, 5, 6
530 DATA 7, 8, 9
540 DATA "apples", 10, "bananas", 5, "oranges", 20
